<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/card"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvComplaintTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@color/heading_text"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/ivForward"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Projector won't turn on in Lab B" />

        <TextView
            android:id="@+id/tvComplaintDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/subtext"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvComplaintTitle"
            tools:text="Oct 24, 10:30 AM" />

        <TextView
            android:id="@+id/tvComplaintStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_status_chip"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="@color/pending_status"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvComplaintDate"
            tools:text="Pending" />

        <com.google.android.material.chip.Chip
            android:id="@+id/tvPriorityBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="HIGH"
            android:textColor="@color/priority_high_text"
            android:textSize="11sp"
            android:textStyle="bold"
            app:chipBackgroundColor="@color/priority_high_bg"
            app:chipStrokeColor="@color/priority_high_stroke"
            app:chipStrokeWidth="1dp"
            app:chipMinHeight="24dp"
            app:ensureMinTouchTargetSize="false"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/tvComplaintStatus"
            app:layout_constraintEnd_toStartOf="@id/ivForward"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@id/tvComplaintStatus"
            app:layout_constraintTop_toTopOf="@id/tvComplaintStatus"
            tools:visibility="visible" />
        <ImageView
            android:id="@+id/ivForward"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/arrow_forward_icon"
            app:tint="@color/icon"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>