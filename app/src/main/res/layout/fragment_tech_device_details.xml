<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarDeviceHub"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/toolbar_bg"
        android:minHeight="?attr/actionBarSize"
        app:navigationIcon="@drawable/arrow_back_icon"
        app:navigationIconTint="@color/icon"
        app:title="Device Profile"
        app:titleTextColor="@color/toolbar_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHeaderDeviceName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:textColor="@color/heading_text"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarDeviceHub"
        tools:text="Dell Optiplex 7090" />

    <TextView
        android:id="@+id/tvHeaderDeviceCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:textColor="@color/subtext"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderDeviceName"
        tools:text="PC-04" />

    <TextView
        android:id="@+id/tvHeaderDot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="•"
        android:textColor="@color/subtext"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/tvHeaderDeviceCode"
        app:layout_constraintStart_toEndOf="@id/tvHeaderDeviceCode"
        app:layout_constraintTop_toTopOf="@id/tvHeaderDeviceCode" />

    <TextView
        android:id="@+id/tvHeaderDeviceType"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:textColor="@color/subtext"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/tvHeaderDeviceCode"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvHeaderDot"
        app:layout_constraintTop_toTopOf="@id/tvHeaderDeviceCode"
        tools:text="Desktop Computer" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutDevice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@color/toolbar_bg"
        app:tabIndicatorColor="@color/label"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@color/label"
        app:tabTextColor="@color/subtext"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderDeviceCode" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerDevice"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabLayoutDevice" />

</androidx.constraintlayout.widget.ConstraintLayout>