<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_admin"
    app:startDestination="@id/navigation_dashboard">

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.android.labassist.admin.DashboardFragment"
        android:label="Home"
        tools:layout="@layout/fragment_admin_dashboard"
        />

    <fragment
        android:id="@+id/navigation_users"
        android:name="com.android.labassist.admin.OrgUsersFragment"
        tools:layout="@layout/fragment_admin_reports"
        />

    <fragment
        android:id="@+id/navigation_admin_profile"
        android:name="com.android.labassist.admin.AdminProfileFragment"
        tools:layout="@layout/fragment_admin_profile"
        android:label="Profile"
        />

    <fragment
        android:id="@+id/navigation_departments"
        android:name="com.android.labassist.admin.DepartmentsFragment"
        tools:layout="@layout/fragment_departments"
        android:label="Labs">

        <action
            android:id="@+id/action_admin_to_department_lab"
            app:destination="@id/navigation_department_labs"/>"

    </fragment>

    <fragment
        android:id="@+id/navigation_admin_lab_detail"
        android:name="com.android.labassist.technician.TechLabDetailFragment"
        tools:layout="@layout/fragment_tech_lab_detail"
        android:label="Lab Details">

        <action
            android:id="@+id/action_admin_to_device_detail"
            app:destination="@id/navigation_admin_device_detail"/>

    </fragment>

    <fragment
        android:id="@+id/navigation_department_labs"
        android:name="com.android.labassist.technician.AssignedLabsFragment"
        tools:layout="@layout/fragment_assigned_labs"
        android:label="Department Labs">

        <action
            android:id="@+id/action_admin_to_lab_detail"
            app:destination="@id/navigation_admin_lab_detail"/>

    </fragment>

    <fragment
        android:id="@+id/navigation_admin_device_detail"
        android:name="com.android.labassist.technician.TechDeviceDetailsFragment"
        tools:layout="@layout/fragment_tech_device_details"
        />

    <fragment
        android:id="@+id/navigation_tech_lab_devices"
        android:name="com.android.labassist.technician.TechLabDevicesFragment"
        tools:layout="@layout/fragment_tech_lab_devices" />

</navigation>