<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_technician"
    app:startDestination="@id/navigation_task">

    <fragment
        android:id="@+id/navigation_task"
        android:name="com.android.labassist.technician.TaskDashboardFragment"
        android:label="Home"
        tools:layout="@layout/fragment_technician_dashboard"
        />

    <fragment
        android:id="@+id/navigation_history"
        android:name="com.android.labassist.technician.HistoryFragment"
        tools:layout="@layout/fragment_technician_history"
        />

    <fragment
        android:id="@+id/navigation_technician_profile"
        android:name="com.android.labassist.technician.TechnicianProfileFragment"
        tools:layout="@layout/fragment_technician_profile"
        android:label="Profile" >

        <action
            android:id="@+id/action_tech_profile_to_settings"
            app:destination="@id/navigation_settings"/>

    </fragment>

    <action
        android:id="@+id/action_global_view_notes"
        app:destination="@id/navigation_view_notes" />

    <fragment
        android:id="@+id/navigation_complaint_bottom_sheet"
        android:name="com.android.labassist.technician.BottomSheetComplaintTech"
        tools:layout="@layout/bottom_sheet_complaint_tech"
        android:label="Complaint Bottom Sheet" />

    <fragment
        android:id="@+id/navigation_view_notes"
        android:name="com.android.labassist.technician.ViewTechNotesFragment"
        tools:layout="@layout/fragment_view_tech_notes"
        android:label="View Notes of Device" />

</navigation>